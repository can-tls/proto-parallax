---
import { profile } from "../data/profile";
---

<section class="sidebar-card" aria-label="Persönliche Daten">
	<h2>Persönliche Daten</h2>

	<ul class="details">
		<li>
			<span class="icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
					<path d="M20 21a8 8 0 0 0-16 0" />
					<circle cx="12" cy="7" r="4" />
				</svg>
			</span>
			<div>
				<p class="label">Name</p>
				<p class="value">{profile.name}</p>
			</div>
		</li>

		<li>
			<span class="icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
					<path d="M3 11l9-7 9 7" />
					<path d="M5 10v10h14V10" />
					<path d="M9 20v-6h6v6" />
				</svg>
			</span>
			<div>
				<p class="label">Adresse</p>
				<p class="value">{profile.addressLine1}</p>
				<p class="value">{profile.addressLine2}</p>
			</div>
		</li>

		<li>
			<span class="icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
					<path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 3.1 5.18 2 2 0 0 1 5.09 3h3a2 2 0 0 1 2 1.72c.12.9.33 1.78.62 2.62a2 2 0 0 1-.45 2.11L9 10a16 16 0 0 0 5 5l.55-.26a2 2 0 0 1 2.11-.45c.84.29 1.72.5 2.62.62A2 2 0 0 1 22 16.92Z" />
				</svg>
			</span>
			<div>
				<p class="label">Telefonnummer</p>
				<p class="value">{profile.phone}</p>
			</div>
		</li>

		<li>
			<span class="icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
					<path d="M4 4h16v16H4z" />
					<path d="m22 6-10 7L2 6" />
				</svg>
			</span>
			<div>
				<p class="label">E-Mail-Adresse</p>
				<p class="value">{profile.email}</p>
			</div>
		</li>

		<li>
			<span class="icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
					<path d="M7 3h10v18H7z" />
					<path d="M9 7h6" />
					<path d="M9 11h6" />
				</svg>
			</span>
			<div>
				<p class="label">Geburtsdatum</p>
				<p class="value">{profile.birthDate}</p>
			</div>
		</li>

		<li>
			<span class="icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
					<path d="M3 10h18" />
					<path d="M5 10l2-4h10l2 4" />
					<path d="M6 10v10h12V10" />
					<path d="M9 20v-5h6v5" />
				</svg>
			</span>
			<div>
				<p class="label">Führerschein</p>
				<p class="value">{profile.driverLicense}</p>
			</div>
		</li>
	</ul>
</section>

<style>
	.sidebar-card {
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	h2 {
		margin: 0;
		font-size: 1rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		font-weight: 700;
	}

	.details {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 16px;
	}

	.details li {
		display: grid;
		grid-template-columns: 22px 1fr;
		gap: 12px;
		align-items: start;
	}

	.icon {
		width: 22px;
		height: 22px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: rgba(255, 255, 255, 0.95);
		margin-top: 2px;
	}

	.icon svg {
		width: 20px;
		height: 20px;
	}

	.label {
		margin: 0;
		font-size: 0.9rem;
		font-weight: 700;
		line-height: 1.2;
	}

	.value {
		margin: 2px 0 0;
		font-size: 0.95rem;
		line-height: 1.4;
		color: rgba(255, 255, 255, 0.85);
	}

	.value + .value {
		margin-top: 0;
	}
</style>